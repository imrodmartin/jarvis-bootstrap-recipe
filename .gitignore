# Composer / Drupal scaffold — managed dependencies, not tracked.
/vendor/
/web/core/
/web/modules/contrib/
/web/themes/contrib/
/web/profiles/contrib/
/web/libraries/

# Site-specific settings + generated files (may contain secrets).
/web/sites/*/settings.php
/web/sites/*/settings.local.php
/web/sites/*/settings.ddev.php
/web/sites/*/files/
/web/sites/*/private/

# OS / editor cruft.
.DS_Store

# Superpowers scratch (progress ledger lives here, git-ignored).
/.superpowers/

# jarvis_ai overlay key entities hold PLAINTEXT API keys — local-only, never
# commit. Scoped to the key files so other AI config (agents/providers) tracks.
/recipes/jarvis_ai/config/key.key.*.yml
