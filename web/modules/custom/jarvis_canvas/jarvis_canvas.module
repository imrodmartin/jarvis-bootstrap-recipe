<?php

/**
 * @file
 * Canvas integration for the Jarvis theme.
 */

use Drupal\canvas\PropShape\CandidateStorablePropShape;
use Drupal\Core\Entity\Display\EntityDisplayInterface;
use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Url;
use Drupal\node\NodeTypeInterface;

/**
 * Implements hook_canvas_storable_prop_shape_alter().
 *
 * Canvas hardwires every block rich-text prop to its locked canvas_html_block
 * format. Swap in the site's Basic/Full HTML formats so editors get a real
 * text-format picker — but ONLY for props that explicitly opt in with the
 * `x-jarvis-html-format` schema marker (currently just the WYSIWYG component).
 *
 * Canvas exposes no per-component scope, but the custom `x-` marker survives
 * shape normalization (see PropShape::normalizePropSchema), so it reaches this
 * hook. Every other rich-text prop lacks the marker and keeps Canvas's default
 * editor.
 */
function jarvis_canvas_canvas_storable_prop_shape_alter(CandidateStorablePropShape $storable_prop_shape): void {
  $schema = $storable_prop_shape->shape->schema;
  if (($schema['contentMediaType'] ?? NULL) === 'text/html'
    && !empty($schema['x-jarvis-html-format'])) {
    $storable_prop_shape->fieldInstanceSettings['allowed_formats'] = ['basic_html', 'full_html'];
  }
}

/**
 * Implements hook_form_FORM_ID_alter() for entity_view_display_edit_form.
 *
 * Canvas ships a "Create with Canvas" CTA on the node display edit form, but
 * its route check (canvas/src/Hook/FieldUiHooks.php) is hardcoded to the
 * pre-11.4 route `entity.entity_view_display.node.default`. Drupal 11.4 split
 * "Manage display" into a controller-based overview plus per-view-mode edit
 * forms (route `entity.entity_view_display.node.view_mode`), so Canvas's CTA
 * never renders and new content types can't get a Canvas template through the
 * UI. Re-add the CTA on the view-mode edit form until upstream fixes it.
 *
 * @see https://www.drupal.org/project/canvas/issues/3498525
 */
function jarvis_canvas_form_entity_view_display_edit_form_alter(array &$form, FormStateInterface $form_state): void {
  // Only the 11.4+ per-view-mode edit form; the pre-11.4 default form is still
  // handled by Canvas itself.
  if (\Drupal::routeMatch()->getRouteName() !== 'entity.entity_view_display.node.view_mode') {
    return;
  }
  // Canvas already queued its own CTA — don't double up.
  $messenger = \Drupal::messenger();
  if ($messenger->messagesByType('canvas_cta')) {
    return;
  }
  $display = $form_state->getFormObject()->getEntity();
  if (!$display instanceof EntityDisplayInterface || $display->getTargetEntityTypeId() !== 'node') {
    return;
  }
  $entity_type_id = $display->getTargetEntityTypeId();
  $bundle = $display->getTargetBundle();
  $entity_type_manager = \Drupal::entityTypeManager();
  $storage = $entity_type_manager->getStorage('content_template');
  // A Canvas template already exists for this bundle: nothing to offer.
  $existing = $storage->getQuery()
    ->accessCheck(FALSE)
    ->condition('content_entity_type_id', $entity_type_id)
    ->condition('content_entity_type_bundle', $bundle)
    ->execute();
  if (!empty($existing)) {
    return;
  }
  if (!$entity_type_manager->getAccessControlHandler('content_template')->createAccess()) {
    return;
  }
  // The boot URL Canvas's own CTA links to: opens the editor for a new
  // template.
  $url = Url::fromRoute('canvas.boot.empty', [], [
    'query' => [
      'from' => 'manage_display',
      'entity_type' => $entity_type_id,
      'bundle' => $bundle,
    ],
  ]);
  // Mirror Canvas's canvas_cta message build so it inherits the same styling.
  $messenger->addMessage([
    '#theme' => 'canvas_cta',
    '#icon' => [
      '#type' => 'html_tag',
      '#tag' => 'span',
      '#attributes' => [
        'class' => ['canvas-cta__icon'],
        'aria-hidden' => 'true',
      ],
    ],
    '#title' => t('New: Design with Drupal Canvas'),
    '#description' => t('Canvas provides a visual, drag-and-drop interface for creating content templates. It offers a modern alternative to the standard "Manage display" table.'),
    '#url' => $url->toString(),
    '#link_title' => t('Create with Canvas'),
  ], 'canvas_cta');
}

/**
 * Implements hook_ENTITY_TYPE_insert() for node_type.
 *
 * Auto-create an empty Canvas Full-content template for every new content type,
 * so the Canvas editor is immediately usable at
 * `/canvas/template/node/<bundle>/full` (Manage display → Full content tab).
 *
 * Canvas's own "Create with Canvas" flow is broken on Drupal 11.4: its CTA
 * route check misses the per-view-mode forms, and even when clicked its boot
 * opens the generic Canvas shell WITHOUT creating a template. This closes that
 * gap so new types don't need the manual clone-an-existing-template workaround.
 *
 * The tree is empty (no field references) so it is valid for ANY bundle,
 * including brand-new types that have no body field yet — the editor is where
 * fields/components get added.
 *
 * @see https://www.drupal.org/project/canvas/issues/3498525
 */
function jarvis_canvas_node_type_insert(NodeTypeInterface $type): void {
  // Config sync brings its own content templates; don't race it.
  if (\Drupal::isConfigSyncing()) {
    return;
  }
  $storage = \Drupal::entityTypeManager()->getStorage('content_template');
  $id = 'node.' . $type->id() . '.full';
  if ($storage->load($id)) {
    return;
  }
  $storage->create([
    'id' => $id,
    'status' => TRUE,
    'content_entity_type_id' => 'node',
    'content_entity_type_bundle' => $type->id(),
    'content_entity_type_view_mode' => 'full',
    'exposed_slots' => [],
    'component_tree' => [],
  ])->save();
}

/**
 * Implements hook_ENTITY_TYPE_delete() for node_type.
 *
 * Remove the auto-created Full-content template when its content type is
 * deleted. An empty template has no config dependency on the bundle (nothing
 * in its component tree references the bundle's fields), so Drupal won't
 * cascade the delete — without this the template is orphaned, pointing at a
 * bundle that no longer exists.
 */
function jarvis_canvas_node_type_delete(NodeTypeInterface $type): void {
  // During config sync the config system handles deletions itself.
  if (\Drupal::isConfigSyncing()) {
    return;
  }
  $template = \Drupal::entityTypeManager()
    ->getStorage('content_template')
    ->load('node.' . $type->id() . '.full');
  if ($template) {
    $template->delete();
  }
}
