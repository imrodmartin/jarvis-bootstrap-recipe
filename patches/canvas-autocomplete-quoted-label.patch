--- a/ui/src/utils/transforms.ts
+++ b/ui/src/utils/transforms.ts
@@ -20,4 +20,9 @@
 // "Label (123)" so the client-side transform extracts the trailing ID.
+// When a label contains a comma or quote, EntityAutocompleteMatcher wraps the
+// WHOLE "Label (123)" string in quotes, so the value ends with `)"` rather than
+// `)`. The optional trailing quote keeps the anchored match working in that case
+// (core's own regex is unanchored and tolerates it).
 // @see \Drupal\Core\Entity\Element\EntityAutocomplete::extractEntityIdFromAutocompleteInput
-export const ENTITY_AUTOCOMPLETE_MATCH = /.+\s\(([^)]+)\)\s*$/;
+// @see \Drupal\Core\Entity\EntityAutocompleteMatcher::getMatches
+export const ENTITY_AUTOCOMPLETE_MATCH = /.+\s\(([^)]+)\)"?\s*$/;
 
